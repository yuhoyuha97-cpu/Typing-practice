rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // 관리자 여부 확인 함수
    function isAdmin() {
      return request.auth != null && (
        exists(/databases/$(database)/documents/admins/$(request.auth.uid)) ||
        request.auth.token.email == 'kdevelop1592@gmail.com'
      );
    }

    // 로그인 여부 확인 함수
    function isLoggedIn() {
      return request.auth != null;
    }

    // 본인 여부 확인 함수
    function isOwner(uid) {
      return request.auth != null && request.auth.uid == uid;
    }

    // ── users 컬렉션 ──────────────────────────────────
    match /users/{uid} {
      // 본인: 읽기/생성 허용.
      allow read: if isOwner(uid) || isAdmin();
      allow create: if isOwner(uid);
      
      // 업데이트 로직:
      // 1. 관리자는 모든 필드 수정 가능
      // 2. 본인의 경우:
      //    가. 아직 프로필 생성이 완료되지 않은 상태(profileComplete 여부 확인 전)라면 초기 항목 세팅(이름, 학반 포함)을 허용한다.
      //    나. 프로필 생성이 완료된 상태라면, 이름('name')과 학반('className')은 수정할 수 없으며 나머지(경험치 등)만 수정 가능.
      allow update: if isAdmin() ||
        (isOwner(uid) && (
          (!('profileComplete' in resource.data) || resource.data.profileComplete != true) ||
          !(request.resource.data.diff(resource.data).affectedKeys().hasAny(['name', 'className']))
        ));
    }

    // ── users 하위 records 컬렉션 ──────────────────────
    match /users/{uid}/records/{recordId} {
      allow read: if isOwner(uid) || isAdmin();
      allow create: if isOwner(uid);
      allow update, delete: if isAdmin();
    }

    // ── admins 컬렉션 ──────────────────────────────────
    match /admins/{uid} {
      allow read: if isAdmin();
      allow write: if false; // Firebase Console에서만 수동 관리
    }

    // ── settings 컬렉션 (랭킹 ON/OFF 등) ──────────────
    match /settings/{doc} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // ── content 컬렉션 (연습 콘텐츠) ──────────────────
    match /content/{doc} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // ── ranking 컬렉션 (캐시된 랭킹 결과) ─────────────
    match /ranking/{doc} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // ── bubbleRanking 컬렉션 (미니게임 랭킹) ──────────────
    match /bubbleRanking/{uid} {
      allow read: if true;
      allow write: if isOwner(uid);
    }
  }
}
